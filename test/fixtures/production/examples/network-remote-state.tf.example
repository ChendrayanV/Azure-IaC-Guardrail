# Optional adapter when the Platform Team publishes networking through an
# AzureRM Terraform backend. Copy this logic into a wrapper root rather than
# editing the reusable application modules.
data "terraform_remote_state" "platform_network" {
  backend = "azurerm"

  config = {
    resource_group_name  = "rg-tfstate-platform"
    storage_account_name = "sttfstateplatform"
    container_name       = "tfstate"
    key                  = "network/production.tfstate"
    use_azuread_auth     = true
  }
}

locals {
  network = {
    virtual_network_id                  = data.terraform_remote_state.platform_network.outputs.virtual_network_id
    application_gateway_subnet_id       = data.terraform_remote_state.platform_network.outputs.public_subnet_ids["application_gateway"]
    app_service_subnet_id               = data.terraform_remote_state.platform_network.outputs.private_subnet_ids["app_service"]
    vmss_subnet_id                      = data.terraform_remote_state.platform_network.outputs.private_subnet_ids["vmss"]
    private_endpoint_subnet_id          = data.terraform_remote_state.platform_network.outputs.private_subnet_ids["private_endpoints"]
    application_gateway_public_ip_id    = data.terraform_remote_state.platform_network.outputs.public_ip_ids["application_gateway"]
    network_security_group_ids          = data.terraform_remote_state.platform_network.outputs.network_security_group_ids
    route_table_ids                     = data.terraform_remote_state.platform_network.outputs.route_table_ids
    azure_monitor_private_link_scope_id = data.terraform_remote_state.platform_network.outputs.azure_monitor_private_link_scope_id
    private_dns_zone_ids                = data.terraform_remote_state.platform_network.outputs.private_dns_zone_ids
  }
}
