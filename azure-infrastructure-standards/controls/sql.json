{
  "$schema": "../schema/control.schema.json",
  "catalogVersion": "2026.06.4",
  "controls": [
    {
      "id": "AZ-SQL-001",
      "title": "SQL servers require a minimum TLS version",
      "description": "Azure SQL servers must declare TLS 1.2 or later.",
      "severity": "warning",
      "resourceTypes": [
        "azurerm_mssql_server"
      ],
      "attribute": "minimum_tls_version",
      "operator": "equals",
      "expected": "1.2",
      "remediation": "Set minimum_tls_version = \"1.2\".",
      "reference": "https://learn.microsoft.com/azure/postgresql/flexible-server/security-overview"
    },
    {
      "id": "AZ-SQL-002",
      "title": "SQL servers must disable public network access",
      "description": "Azure SQL logical servers must use private connectivity.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_mssql_server"
      ],
      "attribute": "public_network_access_enabled",
      "operator": "equals",
      "expected": false,
      "remediation": "Set public_network_access_enabled = false and configure a private endpoint.",
      "reference": "https://learn.microsoft.com/azure/postgresql/flexible-server/security-overview"
    },
    {
      "id": "AZ-SQL-003",
      "title": "SQL servers must restrict outbound network access",
      "description": "Outbound network access from Azure SQL must be explicitly restricted.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_mssql_server"
      ],
      "attribute": "outbound_network_restriction_enabled",
      "operator": "equals",
      "expected": true,
      "remediation": "Set outbound_network_restriction_enabled = true.",
      "reference": "https://learn.microsoft.com/azure/postgresql/flexible-server/security-overview"
    }
  ]
}
