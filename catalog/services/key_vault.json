{
  "$schema": "../schema/service.schema.json",
  "serviceId": "key_vault",
  "displayName": "Key Vault",
  "shortName": "KV",
  "category": "Security",
  "description": "SECRETS KEYS AND CERTIFICATES",
  "color": "#7c3aed",
  "governanceStatus": "approved",
  "icon": "other/02361-icon-service-Backup-Vault.svg",
  "terraform": {
    "resourceType": "azurerm_key_vault",
    "armResourceTypes": [],
    "automaticArguments": [
      "name",
      "resource_group_name",
      "location"
    ],
    "parameters": [
      {
        "key": "tenant_id",
        "label": "Tenant Id",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "sku_name",
        "label": "Sku Name",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "public_network_access_enabled",
        "label": "Public Network Access Enabled",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": false,
        "controlIds": [
          "AZ-KV-001"
        ],
        "remediation": "Set public_network_access_enabled = false and configure a private endpoint."
      },
      {
        "key": "purge_protection_enabled",
        "label": "Purge Protection Enabled",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": true,
        "controlIds": [
          "AZ-KV-002"
        ],
        "remediation": "Set purge_protection_enabled = true."
      },
      {
        "key": "rbac_authorization_enabled",
        "label": "Rbac Authorization Enabled",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": true,
        "controlIds": [
          "AZ-KV-003"
        ],
        "remediation": "Set rbac_authorization_enabled = true and assign least-privilege Key Vault data-plane roles."
      },
      {
        "key": "id",
        "label": "Id",
        "type": "text",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "vault",
        "controlIds": [
          "AZ-KV-004",
          "AZ-KV-008"
        ],
        "remediation": "Create an azurerm_private_endpoint connected to the Key Vault with subresource_names = [\"vault\"]. Create an azurerm_monitor_diagnostic_setting targeting the Key Vault."
      },
      {
        "key": "network_acls.default_action",
        "label": "Network Acls.default Action",
        "type": "text",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "Deny",
        "controlIds": [
          "AZ-KV-005"
        ],
        "remediation": "Set network_acls.default_action = \"Deny\"."
      },
      {
        "key": "network_acls.bypass",
        "label": "Network Acls.bypass",
        "type": "text",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "AzureServices",
        "controlIds": [
          "AZ-KV-006"
        ],
        "remediation": "Set network_acls.bypass = \"AzureServices\" when trusted service access is required."
      },
      {
        "key": "tags",
        "label": "Tags",
        "type": "text",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [
          "AZ-KV-007"
        ],
        "remediation": "Add the required organizational tags."
      },
      {
        "key": "skuName",
        "label": "SKU",
        "type": "select",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "standard",
        "options": [
          "standard",
          "premium"
        ]
      },
      {
        "key": "rbacAuthorization",
        "label": "RBAC authorization",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": true
      },
      {
        "key": "publicNetworkAccess",
        "label": "Public network access",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": false
      },
      {
        "key": "purgeProtection",
        "label": "Purge protection",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": true
      }
    ]
  },
  "controls": [
    {
      "id": "AZ-KV-001",
      "title": "Key Vault public network access must be disabled",
      "description": "Key Vault data-plane access must use approved private connectivity.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_key_vault"
      ],
      "attribute": "public_network_access_enabled",
      "operator": "equals",
      "expected": false,
      "remediation": "Set public_network_access_enabled = false and configure a private endpoint.",
      "reference": "https://learn.microsoft.com/azure/key-vault/general/security-features",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/key-vaults/"
    },
    {
      "id": "AZ-KV-002",
      "title": "Key Vault purge protection must be enabled",
      "description": "Purge protection prevents permanent deletion during the soft-delete retention period.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_key_vault"
      ],
      "attribute": "purge_protection_enabled",
      "operator": "equals",
      "expected": true,
      "remediation": "Set purge_protection_enabled = true.",
      "reference": "https://learn.microsoft.com/azure/key-vault/general/security-features",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/key-vaults/"
    },
    {
      "id": "AZ-KV-003",
      "title": "Key Vault must use Azure RBAC authorization",
      "description": "Azure RBAC provides centralized, least-privilege authorization for Key Vault.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_key_vault"
      ],
      "attribute": "rbac_authorization_enabled",
      "operator": "equals",
      "expected": true,
      "remediation": "Set rbac_authorization_enabled = true and assign least-privilege Key Vault data-plane roles.",
      "reference": "https://learn.microsoft.com/azure/key-vault/general/security-features",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/key-vaults/"
    },
    {
      "id": "AZ-KV-004",
      "title": "Key Vault requires a private endpoint",
      "description": "Each Key Vault must be reachable through an approved vault private endpoint.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_key_vault"
      ],
      "attribute": "id",
      "operator": "relatedResourceExists",
      "expected": "vault",
      "relatedResourceType": "azurerm_private_endpoint",
      "relatedMatchAttribute": "private_service_connection.*.private_connection_resource_id",
      "relatedConditionAttribute": "private_service_connection.*.subresource_names",
      "remediation": "Create an azurerm_private_endpoint connected to the Key Vault with subresource_names = [\"vault\"].",
      "reference": "https://learn.microsoft.com/azure/key-vault/general/security-features",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/key-vaults/"
    },
    {
      "id": "AZ-KV-005",
      "title": "Key Vault network ACLs must deny by default",
      "description": "Key Vault firewall rules must deny traffic that does not match an explicit rule.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_key_vault"
      ],
      "attribute": "network_acls.default_action",
      "operator": "equals",
      "expected": "Deny",
      "planOnly": true,
      "remediation": "Set network_acls.default_action = \"Deny\".",
      "reference": "https://learn.microsoft.com/azure/key-vault/general/network-security",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/key-vaults/key-vault-restrict-default-network-access/"
    },
    {
      "id": "AZ-KV-006",
      "title": "Key Vault should allow trusted Azure services",
      "description": "Approved trusted Microsoft services should be allowed to bypass the Key Vault firewall.",
      "severity": "warning",
      "resourceTypes": [
        "azurerm_key_vault"
      ],
      "attribute": "network_acls.bypass",
      "operator": "equals",
      "expected": "AzureServices",
      "planOnly": true,
      "remediation": "Set network_acls.bypass = \"AzureServices\" when trusted service access is required.",
      "reference": "https://learn.microsoft.com/azure/key-vault/general/network-security",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/key-vaults/keyvault-trusted-services-enabled/"
    },
    {
      "id": "AZ-KV-007",
      "title": "Key Vaults must have tags",
      "description": "Key Vaults must include ownership and governance metadata.",
      "severity": "warning",
      "resourceTypes": [
        "azurerm_key_vault"
      ],
      "attribute": "tags",
      "operator": "exists",
      "remediation": "Add the required organizational tags.",
      "reference": "https://learn.microsoft.com/azure/azure-resource-manager/management/tag-resources",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/key-vaults/key-vault-has-tags/"
    },
    {
      "id": "AZ-KV-008",
      "title": "Key Vaults should send diagnostics to Log Analytics",
      "description": "Centralized Key Vault audit logs support security monitoring and incident response.",
      "severity": "warning",
      "resourceTypes": [
        "azurerm_key_vault"
      ],
      "attribute": "id",
      "operator": "relatedResourceExists",
      "relatedResourceType": "azurerm_monitor_diagnostic_setting",
      "relatedMatchAttribute": "target_resource_id",
      "planOnly": true,
      "remediation": "Create an azurerm_monitor_diagnostic_setting targeting the Key Vault.",
      "reference": "https://learn.microsoft.com/azure/key-vault/general/howto-logging",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/key-vaults/key-vault-log-analytics-enabled/"
    },
    {
      "id": "AZ-KV-KEY-001",
      "title": "Key Vault keys must have an expiration date",
      "description": "Cryptographic keys must expire to enforce lifecycle management and rotation.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_key_vault_key"
      ],
      "attribute": "expiration_date",
      "operator": "exists",
      "remediation": "Set expiration_date and configure an automatic rotation policy.",
      "reference": "https://learn.microsoft.com/azure/key-vault/keys/how-to-configure-key-rotation",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/key-vaults/key-expiration-enabled/"
    },
    {
      "id": "AZ-KV-KEY-002",
      "title": "Key Vault keys should configure automatic rotation",
      "description": "Automatic key rotation reduces exposure from long-lived cryptographic material.",
      "severity": "warning",
      "resourceTypes": [
        "azurerm_key_vault_key"
      ],
      "attribute": "rotation_policy.automatic",
      "operator": "exists",
      "planOnly": true,
      "remediation": "Configure rotation_policy.automatic with an approved rotation interval.",
      "reference": "https://learn.microsoft.com/azure/key-vault/keys/how-to-configure-key-rotation",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/key-vaults/key-expiration-enabled/"
    }
  ]
}
