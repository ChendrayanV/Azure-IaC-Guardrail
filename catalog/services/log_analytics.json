{
  "$schema": "../schema/service.schema.json",
  "serviceId": "log_analytics",
  "displayName": "Log Analytics",
  "shortName": "LOG",
  "category": "DevOps",
  "description": "LOG QUERY AND ANALYSIS",
  "color": "#ca8a04",
  "governanceStatus": "approved",
  "icon": "analytics/00009-icon-service-Log-Analytics-Workspaces.svg",
  "terraform": {
    "resourceType": "azurerm_log_analytics_workspace",
    "armResourceTypes": [],
    "automaticArguments": [
      "name",
      "resource_group_name",
      "location"
    ],
    "parameters": [
      {
        "key": "internet_ingestion_enabled",
        "label": "Internet Ingestion Enabled",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": false,
        "controlIds": [
          "AZ-LAW-001"
        ],
        "remediation": "Configure Azure Monitor Private Link and set internet_ingestion_enabled = false."
      },
      {
        "key": "internet_query_enabled",
        "label": "Internet Query Enabled",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": false,
        "controlIds": [
          "AZ-LAW-002"
        ],
        "remediation": "Configure Azure Monitor Private Link and set internet_query_enabled = false."
      },
      {
        "key": "local_authentication_enabled",
        "label": "Local Authentication Enabled",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": false,
        "controlIds": [
          "AZ-LAW-003"
        ],
        "remediation": "Set local_authentication_enabled = false."
      },
      {
        "key": "sku",
        "label": "SKU",
        "type": "select",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "PerGB2018",
        "options": [
          "Free",
          "PerGB2018",
          "PerNode",
          "Standalone"
        ]
      },
      {
        "key": "retentionDays",
        "label": "Retention days",
        "type": "number",
        "required": false,
        "nestedBlock": false,
        "defaultValue": 30,
        "min": 30,
        "max": 730,
        "step": 1
      }
    ]
  },
  "controls": [
    {
      "id": "AZ-LAW-001",
      "title": "Log Analytics workspaces must disable public ingestion",
      "description": "Log ingestion must use private connectivity through Azure Monitor Private Link.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_log_analytics_workspace"
      ],
      "attribute": "internet_ingestion_enabled",
      "operator": "equals",
      "expected": false,
      "remediation": "Configure Azure Monitor Private Link and set internet_ingestion_enabled = false.",
      "reference": "https://learn.microsoft.com/azure/azure-monitor/logs/private-link-security"
    },
    {
      "id": "AZ-LAW-002",
      "title": "Log Analytics workspaces must disable public queries",
      "description": "Log queries must use private connectivity through Azure Monitor Private Link.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_log_analytics_workspace"
      ],
      "attribute": "internet_query_enabled",
      "operator": "equals",
      "expected": false,
      "remediation": "Configure Azure Monitor Private Link and set internet_query_enabled = false.",
      "reference": "https://learn.microsoft.com/azure/azure-monitor/logs/private-link-security"
    },
    {
      "id": "AZ-LAW-003",
      "title": "Log Analytics workspaces must disable local authentication",
      "description": "Log Analytics access must use Microsoft Entra identities instead of shared keys.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_log_analytics_workspace"
      ],
      "attribute": "local_authentication_enabled",
      "operator": "equals",
      "expected": false,
      "remediation": "Set local_authentication_enabled = false.",
      "reference": "https://learn.microsoft.com/azure/azure-monitor/logs/private-link-security"
    }
  ]
}
