{
  "$schema": "../schema/service.schema.json",
  "serviceId": "database_postgresql",
  "displayName": "Azure Database for PostgreSQL",
  "shortName": "PG",
  "category": "Databases",
  "description": "MANAGED POSTGRESQL",
  "color": "#2563eb",
  "governanceStatus": "not-approved",
  "icon": "databases/10131-icon-service-Azure-Database-PostgreSQL-Server.svg",
  "terraform": {
    "resourceType": "azurerm_postgresql_flexible_server",
    "armResourceTypes": [],
    "automaticArguments": [
      "name",
      "resource_group_name",
      "location"
    ],
    "parameters": [
      {
        "key": "administrator_login",
        "label": "Administrator Login",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "administrator_password",
        "label": "Administrator Password",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "sku_name",
        "label": "Sku Name",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "storage_mb",
        "label": "Storage Mb",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "version",
        "label": "Version",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "public_network_access_enabled",
        "label": "Public Network Access Enabled",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": false,
        "controlIds": [
          "AZ-PG-001"
        ],
        "remediation": "Set public_network_access_enabled = false and configure private connectivity."
      },
      {
        "key": "geo_redundant_backup_enabled",
        "label": "Geo Redundant Backup Enabled",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": true,
        "controlIds": [
          "AZ-PG-002"
        ],
        "remediation": "Set geo_redundant_backup_enabled = true where the selected region and SKU support it."
      },
      {
        "key": "authentication.active_directory_auth_enabled",
        "label": "Authentication.active Directory Auth Enabled",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": true,
        "controlIds": [
          "AZ-PG-003"
        ],
        "remediation": "Set authentication.active_directory_auth_enabled = true."
      },
      {
        "key": "authentication.password_auth_enabled",
        "label": "Authentication.password Auth Enabled",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": false,
        "controlIds": [
          "AZ-PG-004"
        ],
        "remediation": "Set authentication.password_auth_enabled = false and configure an Entra administrator."
      },
      {
        "key": "high_availability.mode",
        "label": "High Availability.mode",
        "type": "text",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "ZoneRedundant",
        "controlIds": [
          "AZ-PG-005"
        ],
        "remediation": "Configure high_availability.mode = \"ZoneRedundant\" where supported."
      },
      {
        "key": "tags",
        "label": "Tags",
        "type": "text",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [
          "AZ-PG-006"
        ],
        "remediation": "Add the required organizational tags."
      },
      {
        "key": "id",
        "label": "Id",
        "type": "text",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [
          "AZ-PG-007"
        ],
        "remediation": "Create an azurerm_monitor_diagnostic_setting targeting the PostgreSQL server."
      }
    ]
  },
  "controls": [
    {
      "id": "AZ-PG-001",
      "title": "PostgreSQL flexible servers must disable public network access",
      "description": "PostgreSQL flexible servers must use delegated networking or private endpoints.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_postgresql_flexible_server"
      ],
      "attribute": "public_network_access_enabled",
      "operator": "equals",
      "expected": false,
      "remediation": "Set public_network_access_enabled = false and configure private connectivity.",
      "reference": "https://learn.microsoft.com/azure/postgresql/flexible-server/security-overview",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/database/"
    },
    {
      "id": "AZ-PG-002",
      "title": "PostgreSQL flexible servers should use geo-redundant backups",
      "description": "Production PostgreSQL servers should protect backups against regional failure.",
      "severity": "warning",
      "resourceTypes": [
        "azurerm_postgresql_flexible_server"
      ],
      "attribute": "geo_redundant_backup_enabled",
      "operator": "equals",
      "expected": true,
      "remediation": "Set geo_redundant_backup_enabled = true where the selected region and SKU support it.",
      "reference": "https://learn.microsoft.com/azure/postgresql/flexible-server/security-overview",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/database/"
    },
    {
      "id": "AZ-PG-003",
      "title": "PostgreSQL flexible servers must enable Microsoft Entra authentication",
      "description": "Centralized Microsoft Entra authentication must be enabled for PostgreSQL.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_postgresql_flexible_server"
      ],
      "attribute": "authentication.active_directory_auth_enabled",
      "operator": "equals",
      "expected": true,
      "planOnly": true,
      "remediation": "Set authentication.active_directory_auth_enabled = true.",
      "reference": "https://learn.microsoft.com/azure/postgresql/flexible-server/security-entra-concepts",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/database/"
    },
    {
      "id": "AZ-PG-004",
      "title": "PostgreSQL flexible servers must disable password authentication",
      "description": "PostgreSQL must use Microsoft Entra authentication instead of local passwords.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_postgresql_flexible_server"
      ],
      "attribute": "authentication.password_auth_enabled",
      "operator": "equals",
      "expected": false,
      "planOnly": true,
      "remediation": "Set authentication.password_auth_enabled = false and configure an Entra administrator.",
      "reference": "https://learn.microsoft.com/azure/postgresql/flexible-server/security-entra-concepts",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/database/"
    },
    {
      "id": "AZ-PG-005",
      "title": "PostgreSQL flexible servers must configure high availability",
      "description": "Production PostgreSQL servers should use zone-redundant high availability.",
      "severity": "warning",
      "resourceTypes": [
        "azurerm_postgresql_flexible_server"
      ],
      "attribute": "high_availability.mode",
      "operator": "equals",
      "expected": "ZoneRedundant",
      "planOnly": true,
      "remediation": "Configure high_availability.mode = \"ZoneRedundant\" where supported.",
      "reference": "https://learn.microsoft.com/azure/postgresql/flexible-server/concepts-high-availability",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/database/"
    },
    {
      "id": "AZ-PG-006",
      "title": "PostgreSQL flexible servers must have tags",
      "description": "PostgreSQL servers must include ownership and governance metadata.",
      "severity": "warning",
      "resourceTypes": [
        "azurerm_postgresql_flexible_server"
      ],
      "attribute": "tags",
      "operator": "exists",
      "remediation": "Add the required organizational tags.",
      "reference": "https://learn.microsoft.com/azure/azure-resource-manager/management/tag-resources",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/database/"
    },
    {
      "id": "AZ-PG-007",
      "title": "PostgreSQL flexible servers should send diagnostics to Log Analytics",
      "description": "Centralized database logs support auditing and incident response.",
      "severity": "warning",
      "resourceTypes": [
        "azurerm_postgresql_flexible_server"
      ],
      "attribute": "id",
      "operator": "relatedResourceExists",
      "relatedResourceType": "azurerm_monitor_diagnostic_setting",
      "relatedMatchAttribute": "target_resource_id",
      "planOnly": true,
      "remediation": "Create an azurerm_monitor_diagnostic_setting targeting the PostgreSQL server.",
      "reference": "https://learn.microsoft.com/azure/postgresql/flexible-server/how-to-configure-and-access-logs",
      "benchmarkReference": "https://avd.aquasec.com/misconfig/azure/database/"
    }
  ]
}
