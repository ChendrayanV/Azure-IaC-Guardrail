{
  "$schema": "../schema/service.schema.json",
  "serviceId": "application_gateway",
  "displayName": "Application Gateway",
  "shortName": "AGW",
  "category": "Networking",
  "description": "WEB TRAFFIC LOAD BALANCER",
  "color": "#2563eb",
  "governanceStatus": "under-review",
  "icon": "networking/03328-icon-service-Application-Gateway-Containers.svg",
  "terraform": {
    "resourceType": "azurerm_application_gateway",
    "armResourceTypes": [],
    "automaticArguments": [
      "name",
      "resource_group_name",
      "location"
    ],
    "parameters": [
      {
        "key": "sku",
        "label": "Sku",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "gateway_ip_configuration",
        "label": "Gateway Ip Configuration",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "frontend_port",
        "label": "Frontend Port",
        "type": "number",
        "required": true,
        "nestedBlock": false,
        "defaultValue": 1,
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "frontend_ip_configuration",
        "label": "Frontend Ip Configuration",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "backend_address_pool",
        "label": "Backend Address Pool",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "backend_http_settings",
        "label": "Backend Http Settings",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "http_listener",
        "label": "Http Listener",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "request_routing_rule",
        "label": "Request Routing Rule",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "tags",
        "label": "Tags",
        "type": "text",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [
          "AZ-AGW-001"
        ],
        "remediation": "Add the required organizational tags to the Application Gateway."
      },
      {
        "key": "http_listener.*.protocol",
        "label": "Http Listener.*.protocol",
        "type": "text",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "Https",
        "controlIds": [
          "AZ-AGW-002"
        ],
        "remediation": "Remove HTTP listeners or replace them with HTTPS listeners that reference an approved TLS certificate."
      },
      {
        "key": "id",
        "label": "Id",
        "type": "text",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [
          "AZ-AGW-005"
        ],
        "remediation": "Create an azurerm_monitor_diagnostic_setting targeting the Application Gateway and enable ApplicationGatewayAccessLog and ApplicationGatewayFirewallLog, or the allLogs category group."
      },
      {
        "key": "ssl_policy.policy_name",
        "label": "Ssl Policy.policy Name",
        "type": "text",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "AppGwSslPolicy20220101S",
        "controlIds": [
          "AZ-AGW-006"
        ],
        "remediation": "Set ssl_policy.policy_type = \"Predefined\" and ssl_policy.policy_name = \"AppGwSslPolicy20220101S\"."
      },
      {
        "key": "sku.tier",
        "label": "Sku.tier",
        "type": "text",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "WAF_v2",
        "controlIds": [
          "AZ-AGW-007"
        ],
        "remediation": "Use sku.tier = \"WAF_v2\" and associate the gateway with an azurerm_web_application_firewall_policy."
      },
      {
        "key": "http2_enabled",
        "label": "Http2 Enabled",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": true,
        "controlIds": [
          "AZ-NET-006"
        ],
        "remediation": "Set http2_enabled = true."
      },
      {
        "key": "fips_enabled",
        "label": "Fips Enabled",
        "type": "boolean",
        "required": false,
        "nestedBlock": false,
        "defaultValue": true,
        "controlIds": [
          "AZ-NET-007"
        ],
        "remediation": "Set fips_enabled = true when required by the workload compliance profile."
      }
    ]
  },
  "controls": [
    {
      "id": "AZ-AGW-001",
      "title": "Application Gateways must have tags",
      "description": "Application Gateways must include ownership, environment, and governance metadata.",
      "severity": "warning",
      "resourceTypes": [
        "azurerm_application_gateway"
      ],
      "attribute": "tags",
      "operator": "exists",
      "remediation": "Add the required organizational tags to the Application Gateway.",
      "reference": "https://learn.microsoft.com/azure/azure-resource-manager/management/tag-resources"
    },
    {
      "id": "AZ-AGW-002",
      "title": "Application Gateway listeners must use HTTPS",
      "description": "Application Gateway client listeners must encrypt ingress traffic with HTTPS.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_application_gateway"
      ],
      "attribute": "http_listener.*.protocol",
      "operator": "equals",
      "expected": "Https",
      "planOnly": true,
      "remediation": "Remove HTTP listeners or replace them with HTTPS listeners that reference an approved TLS certificate.",
      "reference": "https://learn.microsoft.com/azure/application-gateway/ssl-overview"
    },
    {
      "id": "AZ-AGW-005",
      "title": "Application Gateways should send access and firewall logs to Log Analytics",
      "description": "Centralized Application Gateway access and WAF logs support traffic analysis, security monitoring, and incident response.",
      "severity": "warning",
      "resourceTypes": [
        "azurerm_application_gateway"
      ],
      "attribute": "id",
      "operator": "relatedResourceExists",
      "relatedResourceType": "azurerm_monitor_diagnostic_setting",
      "relatedMatchAttribute": "target_resource_id",
      "planOnly": true,
      "remediation": "Create an azurerm_monitor_diagnostic_setting targeting the Application Gateway and enable ApplicationGatewayAccessLog and ApplicationGatewayFirewallLog, or the allLogs category group.",
      "reference": "https://learn.microsoft.com/azure/application-gateway/application-gateway-diagnostics"
    },
    {
      "id": "AZ-AGW-006",
      "title": "Application Gateways must use the latest approved SSL policy",
      "description": "The latest approved predefined SSL policy enforces modern protocols and cipher suites.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_application_gateway"
      ],
      "attribute": "ssl_policy.policy_name",
      "operator": "equals",
      "expected": "AppGwSslPolicy20220101S",
      "planOnly": true,
      "remediation": "Set ssl_policy.policy_type = \"Predefined\" and ssl_policy.policy_name = \"AppGwSslPolicy20220101S\".",
      "reference": "https://learn.microsoft.com/azure/application-gateway/application-gateway-ssl-policy-overview"
    },
    {
      "id": "AZ-AGW-007",
      "title": "Application Gateways must enable WAF",
      "description": "Application Gateways must use the WAF_v2 tier and associate an approved Web Application Firewall policy.",
      "severity": "error",
      "resourceTypes": [
        "azurerm_application_gateway"
      ],
      "attribute": "sku.tier",
      "operator": "equals",
      "expected": "WAF_v2",
      "planOnly": true,
      "remediation": "Use sku.tier = \"WAF_v2\" and associate the gateway with an azurerm_web_application_firewall_policy.",
      "reference": "https://learn.microsoft.com/azure/web-application-firewall/ag/ag-overview"
    },
    {
      "id": "AZ-NET-006",
      "title": "Application Gateway must enable HTTP/2",
      "description": "Application Gateway should use HTTP/2 for modern encrypted client connections.",
      "severity": "warning",
      "resourceTypes": [
        "azurerm_application_gateway"
      ],
      "attribute": "http2_enabled",
      "operator": "equals",
      "expected": true,
      "remediation": "Set http2_enabled = true.",
      "reference": "https://learn.microsoft.com/azure/application-gateway/overview"
    },
    {
      "id": "AZ-NET-007",
      "title": "Application Gateway should enable FIPS mode",
      "description": "FIPS mode should be enabled for workloads requiring validated cryptographic implementations.",
      "severity": "warning",
      "resourceTypes": [
        "azurerm_application_gateway"
      ],
      "attribute": "fips_enabled",
      "operator": "equals",
      "expected": true,
      "remediation": "Set fips_enabled = true when required by the workload compliance profile.",
      "reference": "https://learn.microsoft.com/azure/application-gateway/application-gateway-fips"
    }
  ]
}
