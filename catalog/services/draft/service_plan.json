{
  "$schema": "../../schema/service.schema.json",
  "serviceId": "service_plan",
  "displayName": "App Service Plan",
  "shortName": "ASP",
  "category": "Compute",
  "description": "APP SERVICE COMPUTE",
  "color": "#db2777",
  "governanceStatus": "approved",
  "icon": "app services/00046-icon-service-App-Service-Plans.svg",
  "terraform": {
    "resourceType": "azurerm_service_plan",
    "armResourceTypes": [],
    "automaticArguments": [
      "name",
