    "parameters": [
      {
        "key": "os_type",
        "label": "Os Type",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "sku_name",
        "label": "Sku Name",
        "type": "text",
        "required": true,
        "nestedBlock": false,
        "defaultValue": "",
        "controlIds": [],
        "remediation": ""
      },
      {
        "key": "osType",
        "label": "Operating system",
        "type": "select",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "Linux",
        "options": [
          "Linux",
          "Windows"
        ]
      },
      {
        "key": "skuName",
        "label": "SKU",
        "type": "text",
        "required": false,
        "nestedBlock": false,
        "defaultValue": "P1v3"
      }
    ]
  },
  "controls": []
