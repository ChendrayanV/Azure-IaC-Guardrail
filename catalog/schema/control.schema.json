{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ChendrayanV/Azure-IaC-Guardrail/blob/main/catalog/schema/control.schema.json",
  "title": "Azure infrastructure control catalog",
  "type": "object",
  "required": [
    "catalogVersion",
    "controls"
  ],
  "properties": {
    "catalogVersion": {
      "type": "string"
    },
    "controls": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/control"
      }
    },
    "assurances": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assurance"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "control": {
      "type": "object",
      "required": [
        "id",
        "title",
        "description",
        "severity",
        "resourceTypes",
        "attribute",
        "operator",
        "reference"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9-]+$"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "severity": {
          "enum": [
            "error",
            "warning",
            "information"
          ]
        },
        "resourceTypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "attribute": {
          "type": "string"
        },
        "operator": {
          "enum": [
            "equals",
            "notEquals",
            "exists",
            "oneOf",
            "contains",
            "relatedResourceExists"
          ]
        },
        "expected": {
          "oneOf": [
            {
              "type": [
                "string",
                "number",
                "boolean"
              ]
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": [
                  "string",
                  "number",
                  "boolean"
                ]
              }
            }
          ]
        },
        "remediation": {
          "type": "string"
        },
        "reference": {
          "type": "string",
          "format": "uri"
        },
        "benchmarkReference": {
          "type": "string",
          "format": "uri"
        },
        "planOnly": {
          "type": "boolean"
        },
        "skipStatic": {
          "type": "boolean"
        },
        "conditions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/condition"
          }
        },
        "relatedResourceType": {
          "type": "string"
        },
        "relatedMatchAttribute": {
          "type": "string"
        },
        "relatedConditionAttribute": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "condition": {
      "type": "object",
      "required": [
        "attribute",
        "operator"
      ],
      "properties": {
        "attribute": {
          "type": "string"
        },
        "operator": {
          "enum": [
            "equals",
            "notEquals",
            "exists"
          ]
        },
        "expected": {
          "oneOf": [
            {
              "type": [
                "string",
                "number",
                "boolean"
              ]
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": [
                  "string",
                  "number",
                  "boolean"
                ]
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "assurance": {
      "type": "object",
      "required": [
        "id",
        "title",
        "description",
        "implementation"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9-]+$"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "implementation": {
          "const": "platform"
        },
        "reference": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    }
  }
}
